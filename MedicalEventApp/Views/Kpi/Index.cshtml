@{
    ViewData["Title"] = "KPI Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">KPI Dashboard</h2>
</div>

<div id="loading-panel" class="text-center py-5">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
    <p class="mt-3 mb-0 text-muted">資料計算中，請稍候...</p>
</div>

<div id="kpi-content" class="d-none"></div>

<div id="error-panel" class="alert alert-danger d-none mt-3" role="alert">
    KPI 載入失敗，請稍後重試。
</div>

@section Scripts {
    <script>
        (() => {
            const loadingPanel = document.getElementById("loading-panel");
            const contentPanel = document.getElementById("kpi-content");
            const errorPanel = document.getElementById("error-panel");

            fetch("@Url.Action("Latest", "Kpi")", { method: "GET" })
                .then(response => {
                    if (!response.ok) {
                        throw new Error("Failed to load KPI report.");
                    }
                    return response.text();
                })
                .then(html => {
                    contentPanel.innerHTML = html;
                    contentPanel.classList.remove("d-none");
                })
                .catch(() => {
                    errorPanel.classList.remove("d-none");
                })
                .finally(() => {
                    loadingPanel.classList.add("d-none");
                });
        })();
    </script>
}
